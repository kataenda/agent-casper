# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Casper Network — Official CSPR.cloud endpoints (https://www.casper.network/ai)
CASPER_NODE_URL=https://node.testnet.cspr.cloud
CSPR_CLOUD_API_KEY=your_cspr_cloud_api_key_here
CSPR_CLOUD_BASE_URL=https://api.testnet.cspr.cloud

# x402 Micropayment Protocol — Official facilitator (https://x402-facilitator.cspr.cloud)
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud

# Vault contract (set after deployment)
VAULT_CONTRACT_HASH=hash-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AGENT_ACCOUNT_HASH=account-hash-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AGENT_SECRET_KEY_PATH=./agent_secret_key.pem

# Agent configuration
AGENT_POLL_INTERVAL_SECONDS=60
YIELD_CHANGE_THRESHOLD_BPS=50
MAX_REBALANCES_PER_DAY=5

# x402 Payment (optional)
X402_ENABLED=false
X402_PAYMENT_AMOUNT=1000000

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./casper_agent.db
