# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Casper Network ────────────────────────────────────────────────────────────
CASPER_NODE_URL=https://node.testnet.cspr.cloud/rpc
CSPR_CLOUD_API_KEY=your-cspr-cloud-api-key
CSPR_CLOUD_BASE_URL=https://api.testnet.cspr.cloud

# ── YieldVault Contract ───────────────────────────────────────────────────────
VAULT_CONTRACT_HASH=hash-f6ba9dfa2a236dcc253436c3350f06931465ca94290fad689dfc7c9058c559da
VAULT_CONTRACT_VERSION_HASH=

# ── Admin auth ────────────────────────────────────────────────────────────────
# Shared secret that gates state-mutating endpoints (pause/resume/rebalance/swap/
# deploy/admin-setup). Leave EMPTY to keep them open. Set a long random value to
# require the X-Admin-Token header — paste the same value into the dashboard's
# /api page "Admin token" field to operate those actions.
ADMIN_TOKEN=
# Optional: override the vault owner used for wallet-sign admin auth. Normally the
# owner is read on-chain (the caller of register_agent). Leave EMPTY unless needed.
OWNER_PUBLIC_KEY=

# ── Agent Wallet ──────────────────────────────────────────────────────────────
AGENT_ACCOUNT_HASH=account-hash-88cb6d5e2b0a47b99688e0179a16f5c0c2a16f88c3294b6bf291d9020965843f
AGENT_SECRET_KEY_PATH=./agent_secret_key.pem
# For cloud deployments (Railway/Render) — paste PEM content with \n for newlines
# AGENT_SECRET_KEY_CONTENT=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----

# ── Agent Behaviour ───────────────────────────────────────────────────────────
AGENT_POLL_INTERVAL_SECONDS=300
MAX_REBALANCES_PER_DAY=5

# Post verified RWA prices (PAXG, UST10Y) on-chain via update_rwa_price().
# Rate-limited to once per interval to conserve agent gas.
RWA_ONCHAIN_ENABLED=true
RWA_POST_INTERVAL_SECONDS=3600

# ── x402 Micropayments (optional) ────────────────────────────────────────────
# Official CSPR.cloud `exact` scheme: ed25519-signed EIP-712 TransferWithAuthorization,
# settled by the facilitator as a CEP-18 transfer_with_authorization (real sub-CSPR
# micropayments — no native-transfer floor). Verified against the facilitator /verify.
X402_ENABLED=false
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
# Recipient account-hash address ('00'+hash). If unset, defaults to the agent's address.
X402_PAY_TO=
X402_SETTLE_INTERVAL_SECONDS=3600   # rate-limit on-chain settlement
# CEP-18 token used for settlement. ASSET = 64-hex contract package hash of a token
# exposing transfer_with_authorization; NAME/VERSION form the EIP-712 domain;
# DECIMALS/SYMBOL are display metadata. Amounts below are in token base units.
X402_ASSET=
X402_TOKEN_NAME=
X402_TOKEN_VERSION=1
X402_TOKEN_DECIMALS=6
X402_TOKEN_SYMBOL=
X402_PAYMENT_AMOUNT=1000000        # consumer per-request amount (token base units)
# Mainnet PROVIDER endpoints — other agents pay THIS agent for premium data.
# /x402/decision  → Claude AI rebalance recommendation
# /x402/rwa-feed  → aggregated RWA prices verified on-chain
X402_DECISION_PRICE=5000000        # token base units
X402_RWA_FEED_PRICE=2500000        # token base units
# Per-cycle facilitator settlement (rate-limited by X402_SETTLE_INTERVAL_SECONDS).
# false = verify the proof only, no on-chain settle.
X402_SETTLE_ONCHAIN=true

# ── Real DeFi — CSPR.trade MCP (Casper mainnet, non-custodial) ────────────────
# Safety caps for the /defi/swap endpoint and autonomous execution.
CSPR_TRADE_MAX_AMOUNT_CSPR=25
CSPR_TRADE_MAX_PRICE_IMPACT_PCT=2.0
CSPR_MAINNET_NODE_URL=https://node.cspr.cloud/rpc
# Close the loop: when the AI decides REBALANCE, also execute a small REAL swap on
# mainnet (decision → on-chain execution). OFF by default — this spends real CSPR
# from the agent's mainnet account. Enable only when the agent is funded on mainnet.
DEFI_EXECUTE_ON_REBALANCE=false
DEFI_SWAP_AMOUNT_CSPR=5
DEFI_SWAP_TOKEN_IN=CSPR
DEFI_SWAP_TOKEN_OUT=sCSPR
DEFI_MAX_SWAPS_PER_DAY=1
# Economic discipline — only swap when the move is materially worth the cost.
# Drift: current allocation must be off the AI's target by ≥ this many points.
# Net gain: estimated annualized portfolio APY uplift must clear this many bps.
# (A HIGH-risk de-risk move bypasses the net-gain bar — capital preservation.)
DEFI_MIN_DRIFT_PCT=10
DEFI_MIN_NET_GAIN_BPS=50

# ── Real yield — native staking (opt-in, agent-decided) ───────────────────────
# When enabled, on rebalance the agent delegates part of the vault's CSPR to a
# Casper validator (native staking), sized by the AI's conservative lean and
# capped so a liquidity buffer stays instant-withdrawable. OFF by default — the
# AGENT decides when/how much to stake (no forced toggle).
STAKING_ENABLED=false
VALIDATOR_PUBLIC_KEY=              # testnet validator to delegate to (cspr.live/validators)
STAKE_AMOUNT_CSPR=500             # per stake action (must clear Casper min delegation ~500)
STAKE_BUFFER_CSPR=200            # liquid CSPR always kept for instant withdrawals
STAKE_MAX_PER_DAY=2              # cap on stake actions per day

# ── Agent self-funding + gas-awareness ────────────────────────────────────────
# The agent sweeps the vault's accrued fee reserve to its own gas account
# (collect_fees) and every on-chain action is pre-checked against the agent's real
# balance so it never executes what it can't pay for.
GAS_RESERVE_CSPR=20              # min agent CSPR runway kept before any action
GAS_PER_ACTION_CSPR=6           # est. gas per on-chain action (runway math)

# ── Multi-tenant servicing ────────────────────────────────────────────────────
# Apply each cycle's AI market target to every enrolled vault (drift-gated per
# vault, capped per day to bound gas). ON by default.
MULTI_TENANT_ENABLED=true
TENANT_MIN_DRIFT_PCT=10
TENANT_MAX_REBALANCES_PER_DAY=2

# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
