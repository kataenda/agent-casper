FROM rust:1.81-slim

RUN apt-get update && \
    apt-get install -y pkg-config libssl-dev ca-certificates wabt curl && \
    curl -L https://github.com/WebAssembly/binaryen/releases/download/version_129/binaryen-version_129-x86_64-linux.tar.gz | tar -xz -C /usr/local --strip-components=1 && \
    rustup target add wasm32-unknown-unknown

WORKDIR /contracts
COPY . .

# --cfg odra_module="YieldVault" activates the #[cfg(odra_module="YieldVault")] block
# that Odra's #[odra::module] macro generates — this is where #[no_mangle] fn call() lives.
# Output is NOT redirected so compilation errors are fully visible in CI logs.
RUN RUSTFLAGS='--cfg odra_module="YieldVault" -C target-feature=-bulk-memory' \
    cargo build --target wasm32-unknown-unknown --bin yield_vault_build_contract --release

# Show exports and fail fast if call is missing
RUN echo "=== WASM exports ===" && \
    wasm-objdump -x target/wasm32-unknown-unknown/release/yield_vault_build_contract.wasm | grep -i "export" || true
RUN wasm-objdump -x target/wasm32-unknown-unknown/release/yield_vault_build_contract.wasm | grep '"call"' || \
    (echo "ERROR: 'call' export missing after build" && exit 1)

RUN wasm-strip target/wasm32-unknown-unknown/release/yield_vault_build_contract.wasm

RUN wasm-opt -Oz --signext-lowering \
    target/wasm32-unknown-unknown/release/yield_vault_build_contract.wasm \
    -o target/wasm32-unknown-unknown/release/yield_vault_build_contract.wasm

CMD ["sh", "-c", "cp target/wasm32-unknown-unknown/release/yield_vault_build_contract.wasm /output/yield_vault.wasm"]
