FROM rust:1.81-slim

RUN apt-get update && \
    apt-get install -y pkg-config libssl-dev ca-certificates && \
    rustup target add wasm32-unknown-unknown && \
    cargo install cargo-odra --locked

WORKDIR /contracts
COPY . .

RUN cargo odra build -b casper

CMD ["sh", "-c", "cp wasm/*.wasm /output/"]
