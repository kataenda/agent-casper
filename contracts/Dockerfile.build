FROM rust:1.81-slim

RUN apt-get update && \
    apt-get install -y pkg-config libssl-dev ca-certificates wabt curl && \
    curl -L https://github.com/WebAssembly/binaryen/releases/download/version_129/binaryen-version_129-x86_64-linux.tar.gz | tar -xz -C /usr/local --strip-components=1 && \
    rustup target add wasm32-unknown-unknown && \
    cargo install cargo-odra --locked

WORKDIR /contracts
COPY . .

# cargo-odra build -b casper generates the WASM entry point `call` that Casper requires.
# Direct `cargo build` does NOT generate this export — always use cargo-odra for Casper.
RUN cargo odra build -b casper > /contracts/build.log 2>&1 || (cat /contracts/build.log && exit 1)

# Strip debug info (cargo-odra outputs to wasm/)
RUN wasm-strip wasm/yield_vault.wasm

# Optimize size and lower sign-extension opcodes (required by Casper runtime)
RUN wasm-opt -Oz --signext-lowering wasm/yield_vault.wasm -o wasm/yield_vault.wasm

# Output the final optimized WASM file
CMD ["sh", "-c", "cp wasm/yield_vault.wasm /output/yield_vault.wasm"]
