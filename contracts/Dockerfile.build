FROM rust:1.81-slim

RUN apt-get update && \
    apt-get install -y pkg-config libssl-dev ca-certificates wabt curl && \
    curl -L https://github.com/WebAssembly/binaryen/releases/download/version_129/binaryen-version_129-x86_64-linux.tar.gz | tar -xz -C /usr/local --strip-components=1 && \
    rustup target add wasm32-unknown-unknown

WORKDIR /contracts
COPY . .

# --cfg odra_module="YieldVault" activates the #[cfg(odra_module="YieldVault")] block
# that Odra's #[odra::module] macro generates — this block contains the #[no_mangle] call()
# WASM entry point required by the Casper runtime.
# Without this cfg flag, the call() function is compiled out and the deploy fails with
# "Module doesn't have export call".
RUN RUSTFLAGS='--cfg odra_module="YieldVault" -C target-feature=-bulk-memory' \
    cargo build --target wasm32-unknown-unknown --lib --release 2>&1

# Verify the call export is present before proceeding
RUN echo "=== WASM exports ===" && \
    wasm-objdump -x target/wasm32-unknown-unknown/release/yield_vault.wasm | grep -i "export" || true
RUN wasm-objdump -x target/wasm32-unknown-unknown/release/yield_vault.wasm | grep '"call"' || \
    (echo "ERROR: 'call' export still missing — check odra_module cfg value" && exit 1)

# Strip debug symbols
RUN wasm-strip target/wasm32-unknown-unknown/release/yield_vault.wasm

# Optimize size; --signext-lowering is required by the Casper runtime
RUN wasm-opt -Oz --signext-lowering \
    target/wasm32-unknown-unknown/release/yield_vault.wasm \
    -o target/wasm32-unknown-unknown/release/yield_vault.wasm

CMD ["sh", "-c", "cp target/wasm32-unknown-unknown/release/yield_vault.wasm /output/yield_vault.wasm"]
