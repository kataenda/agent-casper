# Backend API URL (Railway deployment URL)
# Example: https://agent-casper-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (derived from API URL, replace https:// with wss://)
# Example: wss://agent-casper-production.up.railway.app/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
